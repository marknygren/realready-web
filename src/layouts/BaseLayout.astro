---
// Self-host fonts via @fontsource-variable. Replaces the external Google
// Fonts CSS link — eliminates a render-blocking third-party request and
// lets Astro bundle the woff2 files into _astro/ with the standard
// long-cache headers, which addresses Lighthouse's render-blocking +
// efficient-cache warnings.
import '@fontsource-variable/outfit';
import '@fontsource-variable/dm-sans';
import '../styles/global.css';
import MastHead from '../components/MastHead.astro';
import SiteFooter from '../components/SiteFooter.astro';

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  // Search-engine indexable by default. Pages that should stay out of Google
  // (e.g. 404.astro) pass `noindex={true}` explicitly. The site went indexable
  // on 2026-05-27 after the California/Alabama/Arizona/Arkansas state pages
  // shipped; see docs/PLAN.md section 4.
  noindex?: boolean;
  // Suppress masthead + footer (e.g. for a special landing page). Defaults to false.
  bare?: boolean;
  // Inline JSON-LD payloads to inject in <head>. Each one becomes its own
  // <script type="application/ld+json"> tag.
  jsonLd?: unknown[];
}

// Google Search Console verification token. Set via env var so it can be
// updated without touching code once the user signs up at search.google.com.
const GSC_VERIFICATION = import.meta.env.PUBLIC_GSC_VERIFICATION ?? '';

const {
  title,
  description = 'State-specific real estate exam practice. Free questions for all 50 states plus DC.',
  canonical,
  ogImage,
  noindex = false,
  bare = false,
  jsonLd = [],
} = Astro.props;

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://realready.app';
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, Astro.site ?? 'https://realready.app').toString();
const ogImageUrl = ogImage ?? `${siteUrl}/og-default.png`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta name="twitter:card" content="summary_large_image" />

    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    {
      GSC_VERIFICATION && (
        <meta name="google-site-verification" content={GSC_VERIFICATION} />
      )
    }

    {
      jsonLd.map((payload) => (
        <script type="application/ld+json" set:html={JSON.stringify(payload)} />
      ))
    }
  </head>
  <body class="rr-body">
    <a class="skip-link" href="#main">Skip to content</a>
    {bare ? (
      <slot />
    ) : (
      <div class="page">
        <MastHead />
        <main class="main" id="main">
          <slot />
        </main>
        <SiteFooter />
      </div>
    )}
  </body>
</html>
