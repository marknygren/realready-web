---
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Section from '../../components/Section.astro';
import ExamFactsStrip from '../../components/ExamFactsStrip.astro';
import QuizCard from '../../components/QuizCard.astro';
import OtherStatesGrid from '../../components/OtherStatesGrid.astro';
import FaqAccordion from '../../components/FaqAccordion.astro';
import AppStoreBadges from '../../components/AppStoreBadges.astro';
import {
  getStateData,
  getAllStateSummaries,
  type StateData,
} from '../../lib/getStateData';

export const getStaticPaths = (() => {
  const summaries = getAllStateSummaries().filter((s) => s.hasContent);
  return summaries.map((s) => ({
    params: { state: s.slug },
    props: { code: s.code },
  }));
}) satisfies GetStaticPaths;

interface Props {
  code: string;
}

const { code } = Astro.props;
const data: StateData = getStateData(code);

const totalBank = data.totalQuestionsAvailable;
const totalBankPretty = totalBank.toLocaleString();

// SEO-tuned title: leads with "Free", hits the primary keyword "Practice Test",
// stays under 60 chars for SERP.
const title = `Free ${data.name} Real Estate Practice Test | RealReady`;

// Meta description weaves "Practice Test", "Questions and Answers", the state
// exam name, and the total bank size — all things actual searchers type.
const description = `20 free ${data.name} real estate practice questions with answers and explanations. Unlock ${totalBankPretty}+ more in the RealReady app. Pass your ${data.name} real estate exam with confidence.`;

const canonicalUrl = `https://realready.app/states/${data.slug}/`;

// JSON-LD: one Question per practice question + a FAQPage for the state-specific FAQ.
const questionSchemas = data.questions.map((q) => ({
  '@context': 'https://schema.org',
  '@type': 'Question',
  name: q.text,
  acceptedAnswer: {
    '@type': 'Answer',
    text: `${q.options[q.correctIndex]} — ${q.explanation}`,
  },
  suggestedAnswer: q.options
    .filter((_, i) => i !== q.correctIndex)
    .map((distractor) => ({
      '@type': 'Answer',
      text: distractor,
    })),
}));

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: data.faq.map((item) => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.a,
    },
  })),
};

const jsonLd = [...questionSchemas, faqSchema];

// Filter chip labels: All + each distinct category present in the 20 questions.
const filters = [
  { label: 'All', slug: 'all' },
  ...data.categoryLabels.map((label) => {
    const q = data.questions.find((qu) => qu.categoryLabel === label);
    return { label, slug: q?.categorySlug ?? label };
  }),
];
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonicalUrl}
  jsonLd={jsonLd}
>
  {/* HERO */}
  <section class="rr-hero rr-hero--state">
    <div class="container rr-hero__inner rr-hero__inner--state">
      <div class="rr-hero__copy rr-hero__copy--state">
        <p class="rr-eyebrow rr-eyebrow--on-dark rise rise-1">
          <span class="rr-eyebrow__dot" aria-hidden="true"></span>
          {data.name} · Real estate exam prep
        </p>
        <h1 class="rr-hero__title rise rise-2">
          {data.name} Real Estate <em>Practice Test</em>
        </h1>
        <p class="rr-hero__subhead rise rise-3">
          Practice {data.name} real estate questions free below. RealReady
          has <span class="rr-hero__highlight">{totalBankPretty} questions</span>{' '}
          in the bank covering both national real estate principles and{' '}
          {data.name} state law. Pay $17.99 once and own it forever. No
          subscription like the other prep services.
        </p>
        <div class="rr-hero__actions rise rise-4">
          <AppStoreBadges align="start" />
        </div>
      </div>

      <div class="rr-hero__device rise rise-5" aria-hidden="true">
        <div class="rr-halo rr-halo--teal"></div>
        <div class="rr-halo rr-halo--orange"></div>
        <div class="rr-phone">
          <span class="rr-phone__notch"></span>
          <div class="rr-phone__screen rr-phone__screen--hero">
            <img src="/images/hero-home.png" alt="" loading="lazy" />
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* EXAM FACTS STRIP */}
  <Section variant="cool" class="rr-section--tight-bottom">
    <ExamFactsStrip facts={data.examFacts} stateName={data.name} />
  </Section>

  {/* 20 PRACTICE QUESTIONS — the page leads with the test; the intro prose
      now lives below the CTA (see "MORE ABOUT THE EXAM"). */}
  <Section id="practice" class="rr-section--tight-top">
    <header class="practice-header">
      <p class="rr-eyebrow">
        <span class="rr-eyebrow__dot" aria-hidden="true"></span>Practice
      </p>
      <h2 class="rr-h2">
        20 {data.name} Real Estate Test Questions &amp; Answers
      </h2>
      <p class="rr-lead">
        Use this like a free {data.name} real estate practice test: read the
        question, commit to an answer, then tap to reveal the correct answer
        and a plain-English explanation. The ones you miss tell you where to
        focus next.
      </p>

      {filters.length > 1 && (
        <div class="practice-filters" role="tablist" aria-label="Filter by category">
          {filters.map((f) => (
            <button
              type="button"
              class:list={['cat-filter', f.slug === 'all' && 'cat-filter--active']}
              data-cat={f.slug}
              role="tab"
              aria-selected={f.slug === 'all'}
            >
              {f.label}
            </button>
          ))}
        </div>
      )}
    </header>

    <div class="quiz-list">
      {data.questions.map((q, i) => (
        <QuizCard question={q} index={i + 1} total={data.questions.length} />
      ))}
    </div>
  </Section>

  {/* CTA BAND */}
  <Section variant="dark" id="get-app">
    <div class="state-cta">
      <h2 class="rr-h2 rr-h2--on-dark rr-h2--centered">
        Want the rest of {data.name}'s {totalBankPretty}-question bank?
      </h2>
      <p class="state-cta__body state-cta__body--lead">
        The RealReady app has all {totalBankPretty} questions covering both
        national real estate principles and {data.name}-specific law. The full
        app also includes:
      </p>
      <ul class="state-cta__features">
        <li>Short articles that walk you through the why behind each topic</li>
        <li>A missed-question drill mode</li>
        <li>Detailed explanations on every question</li>
        <li>Progress tracking with per-category accuracy</li>
      </ul>
      <p class="state-cta__body state-cta__body--close">
        Unlike other real estate prep apps, we don't cut off access or
        charge a monthly subscription fee. Once you buy, it's yours forever.
      </p>
      <div class="state-cta__badges">
        <AppStoreBadges align="center" />
      </div>
    </div>
  </Section>

  {/* MORE ABOUT THE EXAM: the former top intro, moved below the questions and
      CTA so the page leads with the practice test. This is where the unique,
      state-specific statute content lives. */}
  <Section variant="warm" narrow>
    <p class="rr-eyebrow">
      <span class="rr-eyebrow__dot" aria-hidden="true"></span>About the exam
    </p>
    <h2 class="rr-h2">More about the {data.name} real estate exam</h2>
    <div class="state-intro" set:html={data.intro} />
  </Section>

  {/* STATE-SPECIFIC FAQ */}
  <Section variant="warm" narrow>
    <p class="rr-eyebrow">
      <span class="rr-eyebrow__dot" aria-hidden="true"></span>FAQ
    </p>
    <h2 class="rr-h2">{data.name} real estate exam: your questions answered</h2>
    <FaqAccordion items={data.faq} />
  </Section>

  {/* OTHER STATES */}
  <Section variant="cool">
    <OtherStatesGrid currentCode={data.code} />
  </Section>
</BaseLayout>

<style>
  /* Hero variant for state pages — same two-column layout as the homepage
     so the phone mockup can sit on the right next to the copy. The default
     .rr-hero__inner grid (1fr → 1.15fr/0.85fr at 52rem+) is what we want;
     we just constrain the copy column width slightly. */
  .rr-hero--state {
    /* Use the same dark hero styling */
  }
  .rr-hero__inner--state {
    text-align: left;
  }
  .rr-hero__copy--state {
    max-width: 640px;
  }

  /* Compact-padding utility for adjacent sections — used to collapse the
     gap between the exam-facts strip (cool) and the intro paragraphs
     (warm/narrow). Both default to clamp(3rem, 7vw, 5.5rem) padding which
     visually doubles up; this halves it on the inside edge. */
  :global(.rr-section--tight-bottom) {
    padding-bottom: clamp(1.25rem, 2.5vw, 2rem);
  }
  :global(.rr-section--tight-top) {
    padding-top: clamp(1.25rem, 2.5vw, 2rem);
  }

  /* The bank-size highlight inside the hero subhead. We need this scoped
     class because the global `strong` rule sets color #0a0a0a which is
     unreadable against the navy hero background. */
  .rr-hero__subhead :global(.rr-hero__highlight) {
    color: var(--rr-orange, #ffb703);
    font-weight: 700;
    white-space: nowrap;
  }

  /* Hero action row on state pages — left-align store badges, give them
     a bit more breathing room than the homepage. */
  .rr-hero--state .rr-hero__actions {
    margin-top: 1.5rem;
  }

  /* Mobile: drop the decorative phone mockup so it stops adding ~400px of
     scroll before the questions. Paired with loading="lazy" on the image, a
     hidden mockup is never fetched on phones. Desktop (≥52rem) still shows it. */
  @media (max-width: 52rem) {
    .rr-hero--state .rr-hero__device {
      display: none;
    }
  }

  .state-intro :global(p) {
    font-size: 1.08rem;
    line-height: 1.65;
    color: var(--rr-text-dark, #0f172a);
    margin: 0 0 1rem;
  }
  .state-intro :global(p:last-child) {
    margin-bottom: 0;
  }

  .practice-header {
    max-width: 880px;
    margin: 0 auto 2rem;
    text-align: left;
  }
  .practice-header .rr-h2 {
    margin-top: 0.5rem;
  }
  .practice-header .rr-lead {
    margin-bottom: 1.5rem;
  }

  .practice-filters {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 1rem;
  }
  .cat-filter {
    background: var(--rr-surface, #fff);
    border: 1px solid var(--rr-border, #e2e8f0);
    color: var(--rr-text-dark, #0f172a);
    padding: 0.45rem 0.95rem;
    border-radius: 999px;
    font-size: 0.85rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 150ms ease;
    font-family: var(--font-body);
  }
  .cat-filter:hover {
    border-color: var(--rr-teal);
    color: var(--rr-teal-deep, #1b83a0);
  }
  .cat-filter--active {
    background: var(--rr-navy);
    border-color: var(--rr-navy);
    color: #fff;
  }

  .quiz-list {
    max-width: 880px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .state-cta {
    text-align: center;
    max-width: 720px;
    margin: 0 auto;
  }
  .state-cta__body {
    color: #cdd9e3;
    font-size: 1.05rem;
    line-height: 1.55;
    margin: 1rem 0;
  }
  .state-cta__body--lead {
    margin-bottom: 1.25rem;
  }
  .state-cta__body--close {
    margin-top: 1.25rem;
    margin-bottom: 1.75rem;
  }
  /* Checkmark bullet list, sized to read as a feature snippet between the
     lead and the no-subscription closer. Left-aligned + max-width so the
     bullets don't span the full 720px when the screen is wide. */
  .state-cta__features {
    list-style: none;
    padding: 0;
    margin: 0 auto;
    max-width: 460px;
    text-align: left;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }
  .state-cta__features li {
    position: relative;
    padding-left: 1.6rem;
    color: #e0e7ef;
    font-size: 1rem;
    line-height: 1.5;
  }
  .state-cta__features li::before {
    content: "✓";
    position: absolute;
    left: 0;
    top: 0;
    color: var(--rr-orange, #ffb703);
    font-weight: 700;
    font-size: 1.05rem;
    line-height: 1.4;
  }
  .state-cta__badges {
    display: flex;
    justify-content: center;
  }
</style>

<script>
  // Category filter — toggle visibility of QuizCards via the `hidden` attr.
  document.querySelectorAll<HTMLButtonElement>('.cat-filter').forEach((btn) => {
    btn.addEventListener('click', () => {
      const cat = btn.dataset.cat ?? 'all';
      document
        .querySelectorAll<HTMLElement>('.quiz-card')
        .forEach((card) => {
          card.hidden =
            cat !== 'all' && card.dataset.category !== cat;
        });
      document.querySelectorAll<HTMLButtonElement>('.cat-filter').forEach((b) => {
        const active = b.dataset.cat === cat;
        b.classList.toggle('cat-filter--active', active);
        b.setAttribute('aria-selected', String(active));
      });
    });
  });
</script>
