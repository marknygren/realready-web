---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ValueProps from '../components/ValueProps.astro';
import FeatureGrid from '../components/FeatureGrid.astro';
import HowItWorks from '../components/HowItWorks.astro';
import FaqAccordion, { type FaqItem } from '../components/FaqAccordion.astro';
import ClosingCta from '../components/ClosingCta.astro';
import Section from '../components/Section.astro';

const homepageFaq: FaqItem[] = [
  {
    q: 'Does RealReady cover my state?',
    a: 'Yes. All 50 states plus Washington, D.C. You’ll get both the national principles and the rules specific to the jurisdiction you’re licensing in.',
  },
  {
    q: 'Is it really free to start?',
    a: 'Yes. You can practice on the website right away for free. The app is a one-time unlock for the full state-specific question bank, progress tracking, and missed-question mode — no subscriptions.',
    open: true,
  },
  {
    q: 'What topics are covered?',
    a: 'The national content is organized into nine focused categories, including Property & Land Use, Contracts, Agency, Finance, and Real Estate Math. State-specific rules are broken down by category inside each state’s content, so every topic is covered where it fits.',
  },
  {
    q: 'Is this the same as my pre-license course?',
    a: 'No. RealReady is <strong>exam prep</strong>. Use it after (or alongside) your required course to make sure you pass the state exam itself.',
  },
  {
    q: 'Does it work offline?',
    a: 'Yes. The app caches questions locally so you can study without a signal.',
  },
  {
    q: 'Do you guarantee I’ll pass?',
    a: 'No one can promise you a pass. But targeted practice and honest feedback on what you’re missing is the closest thing.',
  },
];

// WebSite structured data — this is what makes Google show "RealReady" as the
// site name (the bold line above the title in search results) instead of
// falling back to the bare domain "realready.app". Google reads this from the
// homepage and applies the name across the whole domain, so it fixes every
// page at once. Pairs with the og:site_name meta tag in BaseLayout.
const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'RealReady',
  url: 'https://realready.app/',
};
---

<BaseLayout
  title="Free Real Estate Practice Exam, All 50 States | RealReady"
  description="Free real estate practice tests for all 50 states + DC. State-targeted questions with honest feedback. Pass your salesperson or broker exam with confidence."
  jsonLd={[websiteSchema]}
>
  <Hero />

  <ValueProps />

  <div class="container" aria-hidden="true">
    <div class="rule rule--with-mark rr-rule"></div>
  </div>

  <FeatureGrid />

  <HowItWorks />

  <Section variant="warm" id="faq" narrow>
    <p class="rr-eyebrow">
      <span class="rr-eyebrow__dot" aria-hidden="true"></span>FAQ
    </p>
    <h2 class="rr-h2">Common questions</h2>
    <FaqAccordion items={homepageFaq} />
  </Section>

  <ClosingCta />
</BaseLayout>
