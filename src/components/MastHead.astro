---
/**
 * Top nav — RealReady wordmark on the left, primary nav + "Get the App"
 * CTA on the right. Replaces the original Next Chapter Education chrome.
 */
const pathname = Astro.url.pathname;

const navItems: Array<{ href: string; label: string; match?: string }> = [
  { href: '/#features', label: 'Features' },
  { href: '/#how-it-works', label: 'How it works' },
  { href: '/states/', label: 'States', match: '/states/' },
  { href: '/faq/', label: 'FAQ', match: '/faq/' },
];

const isCurrent = (item: { href: string; match?: string }) => {
  if (item.match) {
    return pathname === item.match || pathname.startsWith(item.match);
  }
  return false;
};

// On non-homepage routes, anchor links need to point back to /
const homeAnchor = (href: string) => {
  if (!href.startsWith('/#')) return href;
  return pathname === '/' ? href.slice(1) : href;
};

// "Get the App" anchor target:
//   /                       → #get-app (the closing CTA on the homepage)
//   /states/[slug]/         → #get-app (the bottom CTA band on the state page)
//   anything else           → /#get-app (jump to homepage closing CTA)
const isStatePage = /^\/states\/[^/]+\/?$/.test(pathname);
const isHomepage = pathname === '/';
const appHref = isStatePage || isHomepage ? '#get-app' : '/#get-app';
---

<header class="masthead rr-masthead">
  <div class="container masthead__inner">
    <a href="/" class="wordmark rr-wordmark" aria-label="RealReady, home">
      <img
        src="/images/realready-logo.png"
        alt=""
        class="rr-wordmark__icon"
        width="40"
        height="40"
        loading="eager"
      />
      <span class="rr-wordmark__text">Real<em>Ready</em></span>
    </a>
    <nav class="nav rr-nav" aria-label="Primary">
      <div class="rr-nav__items" id="rr-nav-items">
        {
          navItems.map((item) => (
            <a
              href={homeAnchor(item.href)}
              aria-current={isCurrent(item) ? 'page' : undefined}
            >
              {item.label}
            </a>
          ))
        }
      </div>
      <a href={appHref} class="rr-btn rr-btn--accent rr-btn--nav">
        Get the app
      </a>
      <button
        type="button"
        class="rr-hamburger"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="rr-nav-items"
      >
        <svg
          viewBox="0 0 24 24"
          width="22"
          height="22"
          stroke="currentColor"
          stroke-width="2"
          fill="none"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <line x1="4" y1="6" x2="20" y2="6" class="rr-hamburger__line rr-hamburger__line--top"></line>
          <line x1="4" y1="12" x2="20" y2="12" class="rr-hamburger__line rr-hamburger__line--mid"></line>
          <line x1="4" y1="18" x2="20" y2="18" class="rr-hamburger__line rr-hamburger__line--bot"></line>
        </svg>
      </button>
    </nav>
  </div>
</header>

<script>
  // Mobile nav toggle. Hamburger flips the `is-open` class on .rr-masthead,
  // which the scoped CSS uses to swap the nav-link group between hidden and
  // a dropdown panel positioned under the masthead. Clicking a link closes
  // the menu so users don't see it linger after navigating.
  document.addEventListener('DOMContentLoaded', () => {
    const header = document.querySelector<HTMLElement>('.rr-masthead');
    const hamb = header?.querySelector<HTMLButtonElement>('.rr-hamburger');
    if (!header || !hamb) return;

    hamb.addEventListener('click', () => {
      const isOpen = header.classList.toggle('is-open');
      hamb.setAttribute('aria-expanded', String(isOpen));
      hamb.setAttribute('aria-label', isOpen ? 'Close menu' : 'Open menu');
    });

    header.querySelectorAll<HTMLAnchorElement>('.rr-nav__items a').forEach((a) => {
      a.addEventListener('click', () => {
        header.classList.remove('is-open');
        hamb.setAttribute('aria-expanded', 'false');
        hamb.setAttribute('aria-label', 'Open menu');
      });
    });
  });
</script>

<style>
  /* Masthead row breathes a little more now that the logo image is in it.
     position: relative anchors the mobile dropdown's absolute positioning
     to the masthead. */
  :global(.rr-masthead) {
    padding-top: 0.85rem;
    padding-bottom: 0.85rem;
    position: relative;
  }
  :global(.rr-masthead .masthead__inner) {
    align-items: center;
  }

  /* Desktop: nav-link group lays out inline, hamburger hidden. */
  :global(.rr-nav__items) {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }
  :global(.rr-hamburger) {
    display: none;
    background: transparent;
    border: 0;
    padding: 0.4rem;
    color: var(--rr-navy);
    cursor: pointer;
    border-radius: 8px;
    line-height: 0;
  }
  :global(.rr-hamburger:hover) {
    background: rgba(2, 48, 71, 0.06);
  }
  :global(.rr-hamburger:focus-visible) {
    outline: 2px solid var(--rr-orange);
    outline-offset: 2px;
  }

  /* RealReady-scoped wordmark — single-word brand, no uppercase, tight kerning.
     Overrides .wordmark's uppercase + 0.02em letter-spacing inherited from
     global.css, which was making the Real/Ready split read as two words.
     Now also hosts the app-icon image to the left of the text. */
  :global(.rr-wordmark) {
    font-size: 1.4rem;
    font-weight: 700;
    letter-spacing: -0.015em;
    text-transform: none;
    color: var(--rr-navy);
    gap: 0.55rem;
    align-items: center;
  }
  :global(.rr-wordmark__icon) {
    width: 40px;
    height: 40px;
    display: block;
    border-radius: 9px;
    object-fit: cover;
  }
  :global(.rr-wordmark__text) {
    display: inline-flex;
    line-height: 1;
  }
  :global(.rr-wordmark em) {
    color: var(--rr-orange-deep, #fb8500);
    font-weight: 700;
    font-style: normal;
    margin-left: -0.02em;
  }
  :global(.rr-wordmark:hover),
  :global(.rr-wordmark:hover em) {
    color: var(--rr-teal);
  }

  /* Compact pill sized for the nav line. Selector is .rr-nav .rr-btn--nav
     (extra class) so it beats the base .rr-btn (var(--text-base) = 1rem)
     by specificity instead of relying on cascade order. Type metrics match
     the nav links so the button sits inline with the other items. */
  :global(.rr-nav .rr-btn--nav) {
    padding: 0.4rem 1.05rem;
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    border-radius: 999px;
    line-height: 1;
    /* Quieter than the standalone .rr-btn--accent shadow */
    box-shadow: 0 2px 5px rgba(255, 183, 3, 0.22);
  }
  :global(.rr-nav .rr-btn--nav:hover) {
    transform: translateY(-1px);
    box-shadow: 0 4px 9px rgba(255, 183, 3, 0.32);
  }

  /* Nav alignment + spacing tweaks. Bumped from var(--text-xs) (0.75rem) to
     0.9rem so the links read as real text instead of micro-labels, and to
     line up visually with the larger 1.4rem wordmark next to them. */
  :global(.rr-nav) {
    align-items: center;
    font-size: 0.9rem;
    letter-spacing: 0.12em;
    gap: 1.5rem;
  }

  @media (max-width: 640px) {
    /* Force the masthead row to stay on one line at narrow widths.
       Overrides the global .masthead__inner flex-wrap + the small-screens
       column-direction rule in global.css that was stacking everything. */
    :global(.rr-masthead .masthead__inner) {
      flex-wrap: nowrap;
      flex-direction: row;
      align-items: center;
      gap: 0.5rem;
    }
    :global(.rr-nav) {
      gap: 0.6rem;
      font-size: 0.78rem;
    }
    :global(.rr-nav .rr-btn--nav) {
      padding: 0.4rem 0.85rem;
      font-size: 0.74rem;
      letter-spacing: 0.08em;
    }
    :global(.rr-wordmark) {
      font-size: 1.2rem;
    }
    :global(.rr-wordmark__icon) {
      width: 34px;
      height: 34px;
    }

    /* Hide the inline nav-link group, show the hamburger button. */
    :global(.rr-nav__items) {
      display: none;
    }
    :global(.rr-hamburger) {
      display: inline-flex;
      align-items: center;
      justify-content: center;
    }

    /* When the hamburger is toggled, the nav-link group reappears as an
       absolute-positioned dropdown panel underneath the masthead — full
       width, vertically stacked, light card-like background. */
    :global(.rr-masthead.is-open .rr-nav__items) {
      display: flex;
      flex-direction: column;
      align-items: stretch;
      gap: 0;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      background: var(--color-bg, #fff);
      padding: 0.5rem 1rem;
      border-top: 1px solid var(--color-rule, #e2e8f0);
      box-shadow: 0 12px 24px rgba(15, 23, 42, 0.08);
      z-index: 100;
    }
    :global(.rr-masthead.is-open .rr-nav__items a) {
      padding: 0.85rem 0.25rem;
      border-bottom: 1px solid rgba(2, 48, 71, 0.06);
      font-size: 0.85rem;
      letter-spacing: 0.12em;
    }
    :global(.rr-masthead.is-open .rr-nav__items a:last-child) {
      border-bottom: 0;
    }
  }
</style>
