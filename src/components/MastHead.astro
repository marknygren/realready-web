---
/**
 * Top nav — RealReady wordmark on the left, primary nav + "Get the App"
 * CTA on the right. Replaces the original Next Chapter Education chrome.
 */
const pathname = Astro.url.pathname;

const navItems: Array<{ href: string; label: string; match?: string }> = [
  { href: '/#features', label: 'Features' },
  { href: '/#how-it-works', label: 'How it works' },
  { href: '/states/', label: 'States', match: '/states/' },
  { href: '/faq/', label: 'FAQ', match: '/faq/' },
];

const isCurrent = (item: { href: string; match?: string }) => {
  if (item.match) {
    return pathname === item.match || pathname.startsWith(item.match);
  }
  return false;
};

// On non-homepage routes, anchor links need to point back to /
const homeAnchor = (href: string) => {
  if (!href.startsWith('/#')) return href;
  return pathname === '/' ? href.slice(1) : href;
};

// "Get the App" anchor target:
//   /                       → #get-app (the closing CTA on the homepage)
//   /states/[slug]/         → #get-app (the bottom CTA band on the state page)
//   anything else           → /#get-app (jump to homepage closing CTA)
const isStatePage = /^\/states\/[^/]+\/?$/.test(pathname);
const isHomepage = pathname === '/';
const appHref = isStatePage || isHomepage ? '#get-app' : '/#get-app';
---

<header class="masthead rr-masthead">
  <div class="container masthead__inner">
    <a href="/" class="wordmark rr-wordmark" aria-label="RealReady, home">
      <img
        src="/images/realready-logo.png"
        alt=""
        class="rr-wordmark__icon"
        width="40"
        height="40"
        loading="eager"
      />
      <span class="rr-wordmark__text">Real<em>Ready</em></span>
    </a>
    <nav class="nav rr-nav" aria-label="Primary">
      {
        navItems.map((item) => (
          <a
            href={homeAnchor(item.href)}
            aria-current={isCurrent(item) ? 'page' : undefined}
          >
            {item.label}
          </a>
        ))
      }
      <a href={appHref} class="rr-btn rr-btn--accent rr-btn--nav">
        Get the app
      </a>
    </nav>
  </div>
</header>

<style>
  /* Masthead row breathes a little more now that the logo image is in it. */
  :global(.rr-masthead) {
    padding-top: 0.85rem;
    padding-bottom: 0.85rem;
  }
  :global(.rr-masthead .masthead__inner) {
    align-items: center;
  }

  /* RealReady-scoped wordmark — single-word brand, no uppercase, tight kerning.
     Overrides .wordmark's uppercase + 0.02em letter-spacing inherited from
     global.css, which was making the Real/Ready split read as two words.
     Now also hosts the app-icon image to the left of the text. */
  :global(.rr-wordmark) {
    font-size: 1.4rem;
    font-weight: 700;
    letter-spacing: -0.015em;
    text-transform: none;
    color: var(--rr-navy);
    gap: 0.55rem;
    align-items: center;
  }
  :global(.rr-wordmark__icon) {
    width: 40px;
    height: 40px;
    display: block;
    border-radius: 9px;
    object-fit: cover;
  }
  :global(.rr-wordmark__text) {
    display: inline-flex;
    line-height: 1;
  }
  :global(.rr-wordmark em) {
    color: var(--rr-orange-deep, #fb8500);
    font-weight: 700;
    font-style: normal;
    margin-left: -0.02em;
  }
  :global(.rr-wordmark:hover),
  :global(.rr-wordmark:hover em) {
    color: var(--rr-teal);
  }

  /* Compact pill sized for the nav line. Type metrics match the nav links
     (.rr-nav) so the button sits cleanly inline with the other items. */
  :global(.rr-btn--nav) {
    padding: 0.5rem 1.05rem;
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    border-radius: 999px;
    line-height: 1;
    /* Quieter than the standalone .rr-btn--accent shadow */
    box-shadow: 0 2px 5px rgba(255, 183, 3, 0.22);
  }
  :global(.rr-btn--nav:hover) {
    transform: translateY(-1px);
    box-shadow: 0 4px 9px rgba(255, 183, 3, 0.32);
  }

  /* Nav alignment + spacing tweaks. Bumped from var(--text-xs) (0.75rem) to
     0.9rem so the links read as real text instead of micro-labels, and to
     line up visually with the larger 1.4rem wordmark next to them. */
  :global(.rr-nav) {
    align-items: center;
    font-size: 0.9rem;
    letter-spacing: 0.12em;
    gap: 1.5rem;
  }

  @media (max-width: 640px) {
    :global(.rr-nav) {
      gap: 0.9rem;
      font-size: 0.78rem;
    }
    :global(.rr-btn--nav) {
      padding: 0.45rem 0.9rem;
      letter-spacing: 0.1em;
    }
    :global(.rr-wordmark) {
      font-size: 1.2rem;
    }
    :global(.rr-wordmark__icon) {
      width: 34px;
      height: 34px;
    }
  }
</style>
