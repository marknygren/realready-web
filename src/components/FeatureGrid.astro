---
/**
 * 6-feature card grid on a cool band — "Built around how you actually study."
 * Ported 1:1 from nextchapterapps RealReady page.
 */
import Section from './Section.astro';
---

<Section variant="cool" id="features">
  <p class="rr-eyebrow">
    <span class="rr-eyebrow__dot" aria-hidden="true"></span>Features
  </p>
  <h2 class="rr-h2">Built around how you actually study.</h2>
  <p class="rr-lead">
    Short, focused practice modes that fit the way you already study. On a
    break, on the bus, before bed.
  </p>

  <ul class="rr-features">
    <li class="rr-feature">
      <span class="rr-icon" aria-hidden="true">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.75"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <circle cx="12" cy="12" r="10"></circle>
          <polyline points="12 6 12 12 16 14"></polyline>
        </svg>
      </span>
      <h3 class="rr-feature__title">Daily practice</h3>
      <p class="rr-feature__body">
        Quick 10 sessions serve up ten random questions across all categories.
        Great for a coffee break, a commute, or before bed.
      </p>
    </li>
    <li class="rr-feature">
      <span class="rr-icon" aria-hidden="true">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.75"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path>
          <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path>
        </svg>
      </span>
      <h3 class="rr-feature__title">Nine categories of content</h3>
      <p class="rr-feature__body">
        The national content is organized into nine focused categories including
        Property &amp; Land Use, Contracts, Agency, Finance, and Real Estate
        Math. Drill in wherever you need the most work.
      </p>
    </li>
    <li class="rr-feature">
      <span class="rr-icon" aria-hidden="true">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.75"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M3 12a9 9 0 0 1 9-9 9.75 9.75 0 0 1 6.74 2.74L21 8"></path>
          <path d="M21 3v5h-5"></path>
          <path d="M21 12a9 9 0 0 1-9 9 9.75 9.75 0 0 1-6.74-2.74L3 16"></path>
          <path d="M8 16H3v5"></path>
        </svg>
      </span>
      <h3 class="rr-feature__title">Missed Questions</h3>
      <p class="rr-feature__body">
        Review and retake only the questions you got wrong. Focused drilling on
        your weak spots turns them into strengths, fast.
      </p>
    </li>
    <li class="rr-feature">
      <span class="rr-icon" aria-hidden="true">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.75"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <polyline points="22 7 13.5 15.5 8.5 10.5 2 17"></polyline>
          <polyline points="16 7 22 7 22 13"></polyline>
        </svg>
      </span>
      <h3 class="rr-feature__title">Progress Tracking</h3>
      <p class="rr-feature__body">
        Visual rings show overall completion, per-category accuracy, and
        mastery. See where you&rsquo;re strong and where to focus next.
      </p>
    </li>
    <li class="rr-feature">
      <span class="rr-icon" aria-hidden="true">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.75"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path
            d="M14.106 5.553a2 2 0 0 0 1.788 0l3.659-1.83A1 1 0 0 1 21 4.619v12.764a1 1 0 0 1-.553.894l-4.553 2.277a2 2 0 0 1-1.788 0l-4.212-2.106a2 2 0 0 0-1.788 0l-3.659 1.83A1 1 0 0 1 3 19.381V6.618a1 1 0 0 1 .553-.894l4.553-2.277a2 2 0 0 1 1.788 0z"
          ></path>
          <path d="M15 5.764v15"></path>
          <path d="M9 3.236v15"></path>
        </svg>
      </span>
      <h3 class="rr-feature__title">All 50 States</h3>
      <p class="rr-feature__body">
        Select your state at setup and switch anytime. National and
        state-specific content is included for every jurisdiction, plus
        Washington, D.C.
      </p>
    </li>
    <li class="rr-feature">
      <span class="rr-icon" aria-hidden="true">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.75"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <line x1="2" x2="22" y1="2" y2="22"></line>
          <path d="M8.5 16.5a5 5 0 0 1 7 0"></path>
          <path d="M2 8.82a15 15 0 0 1 4.17-2.65"></path>
          <path d="M10.66 5c4.01-.36 8.14.9 11.34 3.76"></path>
          <path d="M16.85 11.25a10 10 0 0 1 2.22 1.68"></path>
          <path d="M5 13a10 10 0 0 1 5.24-2.76"></path>
          <line x1="12" x2="12.01" y1="20" y2="20"></line>
        </svg>
      </span>
      <h3 class="rr-feature__title">Study without a signal</h3>
      <p class="rr-feature__body">
        Practice on a flight, on the subway, or anywhere reception drops. Your
        questions come with you, wifi or not.
      </p>
    </li>
  </ul>
</Section>
