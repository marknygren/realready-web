---
/**
 * Apple App Store + Google Play badges, side-by-side.
 * Self-hosted assets in public/images/.
 */
interface Props {
  align?: 'start' | 'center';
}

const { align = 'start' } = Astro.props;

const APP_STORE_URL = 'https://apps.apple.com/app/id6767036698';
const PLAY_STORE_URL =
  'https://play.google.com/store/apps/details?id=com.realready.app';
---

<div class:list={['app-badges', `app-badges--${align}`]}>
  <a
    href={APP_STORE_URL}
    class="app-badge app-badge--apple"
    aria-label="Download RealReady on the App Store"
    rel="noopener"
  >
    <img
      src="/images/app-store-badge.svg"
      alt="Download on the App Store"
      width="180"
      height="60"
      loading="lazy"
    />
  </a>
  <a
    href={PLAY_STORE_URL}
    class="app-badge app-badge--google"
    aria-label="Get RealReady on Google Play"
    rel="noopener"
  >
    <img
      src="/images/google-play-badge.png"
      alt="Get it on Google Play"
      width="201"
      height="60"
      loading="lazy"
    />
  </a>
</div>

<style>
  /*
   * Apple SVG aspect: 119.66 × 40 (≈3:1)
   * Google PNG aspect (after trimming transparent padding): 564 × 168 (≈3.36:1)
   * At a shared 60px display height the two render at very similar widths
   * (~180 vs ~201), so they read as visually balanced side-by-side.
   */
  .app-badges {
    display: flex;
    gap: 0.85rem;
    align-items: center;
    /* No wrap — we shrink instead so the two badges stay on one row even on
       narrow phones. The Apple SVG + Google PNG are aspect-fixed so they
       scale cleanly via height. */
    flex-wrap: nowrap;
  }
  .app-badges--center {
    justify-content: center;
  }
  .app-badge {
    display: inline-flex;
    transition: transform 150ms ease;
    border: 0;
    flex: 0 0 auto;
  }
  .app-badge:hover {
    transform: translateY(-2px);
  }
  .app-badge img {
    height: 60px;
    width: auto;
    display: block;
  }

  /* Mobile: shrink height + tighten gap so badges stay side-by-side
     inside a 320–375px viewport with the container's padding. */
  @media (max-width: 560px) {
    .app-badges {
      gap: 0.55rem;
    }
    .app-badge img {
      height: 44px;
    }
  }
  @media (max-width: 380px) {
    .app-badge img {
      height: 40px;
    }
  }
</style>
